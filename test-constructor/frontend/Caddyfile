:80 {
    encode gzip zstd

    handle /api/* {
        reverse_proxy testing-backend:8080
    }

    handle /login {
        reverse_proxy testing-backend:8080
    }

    handle /register {
        reverse_proxy testing-backend:8080
    }

    handle /sso/exchange {
        reverse_proxy testing-backend:8080
    }

    handle /assets/* {
        root * /srv/testing-front
        header Cache-Control "public, max-age=31536000, immutable"
        file_server
    }

    handle {
        root * /srv/testing-front
        header Cache-Control "no-cache"
        try_files {path} /index.html
        file_server
    }
}
