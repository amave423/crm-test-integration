# Root deploy environment for CRM + testing module
APP_DOMAIN=crm.example.com
TESTING_DOMAIN=testing.example.com

VITE_API_BASE=
VITE_USE_MOCK=false
VITE_TESTING_URL=https://testing.example.com

DJANGO_DEBUG=0
DJANGO_SECRET_KEY=change-this-to-a-long-random-secret
DJANGO_ALLOWED_HOSTS=crm.example.com,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://crm.example.com
DJANGO_CORS_ALLOW_ALL_ORIGINS=0
DJANGO_CORS_ALLOWED_ORIGINS=https://crm.example.com,https://testing.example.com
DJANGO_CACHE_DIR=/app/.cache

DB_NAME=crm_bd
DB_USER=crm_user
DB_PASSWORD=change-this-crm-database-password
DB_HOST=db
DB_PORT=5432

CRM_ADMIN_EMAIL=admin@example.com
CRM_ADMIN_PASSWORD=change-this-crm-admin-password
CRM_ADMIN_FIRST_NAME=CRM
CRM_ADMIN_LAST_NAME=Admin
# Set to 1 only if you need to reset the existing CRM admin password on deploy.
CRM_ADMIN_RESET_PASSWORD=0

TESTING_SERVICE_TOKEN=change-this-shared-service-token
TESTING_SERVICE_URL=https://testing.example.com
TESTING_SSO_TICKET_TTL_SECONDS=300

TESTING_DB_NAME=test_constructor
TESTING_DB_USER=testing_user
TESTING_DB_PASSWORD=change-this-testing-database-password
TESTING_ADMIN_EMAIL=admin@example.com
TESTING_ADMIN_PASSWORD=change-this-testing-admin-password
TESTING_JWT_SECRET=change-this-testing-jwt-secret

VK_ENABLED=1
VK_GROUP_ID=123456789
VK_ACCESS_TOKEN=vk1.change-this-token
VK_API_VERSION=5.199
VK_API_BASE_URL=https://api.vk.com/method
VK_CALLBACK_SECRET=change-this-callback-secret
VK_CONFIRMATION_CODE=change-this-confirmation-code
VK_CHAT_LINK_BASE_URL=https://crm.example.com
VK_BOT_FRONTEND_URL=https://crm.example.com
VK_ORG_CHAT_URL=
VK_ORG_CHAT_PEER_ID=0
VK_CHAT_LINK_MAX_AGE_SECONDS=2592000
VK_REQUEST_TIMEOUT_SECONDS=5

AUTOMATION_INTERVAL_SECONDS=60
RUN_MIGRATIONS=1
RUN_COLLECTSTATIC=1

